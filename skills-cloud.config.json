{
  "version": 1,
  "layer": "cloud",
  "sources": [
    {
      "id": "context7",
      "type": "github",
      "value": "https://github.com/upstash/context7",
      "enabled": true,
      "mode": "runtime-adapter",
      "runtime": {
        "preferred": ["mcp", "cli"],
        "commands": ["npx ctx7@latest"],
        "env": ["CONTEXT7_API_KEY"],
        "requiresUserSetup": true,
        "notes": "Prefer Context7 MCP when available; use ctx7 CLI as the fallback path for current documentation."
      },
      "context7": {
        "libraryId": "/websites/context7",
        "libraryName": "Context7",
        "query": "Create or update a Codex skill for Context7. Prefer official installation, MCP/CLI setup, GitHub Actions integration, and agent workflow guidance."
      }
    },
    {
      "id": "firecrawl",
      "type": "github",
      "value": "https://github.com/firecrawl/firecrawl",
      "enabled": true,
      "mode": "runtime-adapter",
      "runtime": {
        "preferred": ["mcp", "api"],
        "commands": [],
        "env": ["FIRECRAWL_API_KEY"],
        "requiresUserSetup": true,
        "notes": "Prefer installed Firecrawl skills or MCP/API tooling; the cloud skill should describe setup, credentials, and fallbacks."
      },
      "context7": {
        "libraryId": "/firecrawl/skills",
        "libraryName": "Firecrawl Skills",
        "query": "Create or update a Codex skill for Firecrawl. Prefer official Firecrawl skills, MCP/CLI/API setup, API key requirements, and agent workflow guidance."
      }
    },
    {
      "id": "ui-ux-pro-max",
      "type": "github",
      "value": "https://github.com/nextlevelbuilder/ui-ux-pro-max-skill",
      "enabled": true,
      "mode": "vendor",
      "context7": {
        "libraryId": "/nextlevelbuilder/ui-ux-pro-max-skill",
        "libraryName": "UI UX Pro Max",
        "query": "Create or update a Codex skill for ui-ux-pro-max. Prefer the existing skill content, design workflow rules, and agent usage guidance."
      }
    },
    {
      "id": "trpc",
      "type": "github",
      "value": "https://github.com/trpc/trpc",
      "enabled": true,
      "mode": "generated"
    },
    {
      "id": "springboot",
      "type": "github",
      "value": "https://github.com/spring-projects/spring-boot",
      "enabled": true,
      "mode": "generated"
    }
  ],
  "provider": "deepseek",
  "skillsDir": ".agents/skills",
  "pages": {
    "outDir": "dist/cloud-ui",
    "dataDir": "public/data"
  }
}
